# ===========================================
# Project Pantheon - Environment Variables
# ===========================================

# Database
PG_CONNECTION_STRING=postgresql://user:password@postgres:5432/pantheon
REDIS_URL=redis://redis:6379/0

# Telegram
TELEGRAM_TOKEN=
DEBOUNCE_TIME=5.0
LLM_CALLS_PER_MINUTE=5

# LLM Providers (via LiteLLM)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Agent Configuration
LLM_MODEL=gpt-4o-mini
EMBED_MODEL=openai:text-embedding-3-small
VECTOR_DIMS=1536

# LangChain Tracing (optional)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true

# Phase Configuration
PHASE_TIMEOUT_SECONDS=60
MAX_DEBATE_ROUNDS=3

# Logging
LOG_LEVEL=INFO
