# ===========================================
# Project Pantheon - Environment Variables
# ===========================================

# Database
PG_CONNECTION_STRING=postgresql://user:password@postgres:5432/pantheon
REDIS_URL=redis://redis:6379/0

# Telegram
TELEGRAM_TOKEN=
DEBOUNCE_TIME=5.0
LLM_CALLS_PER_MINUTE=5

# LLM Providers (via LiteLLM)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
NVIDIA_NIM_API_KEY=   # optional — NVIDIA NIM free-tier (DeepSeek V3, Kimi K2)

# Agent Configuration
LLM_MODEL=gpt-4o-mini
EMBED_MODEL=openai:text-embedding-3-small
VECTOR_DIMS=1536

# Multi-Model Configuration (Phase workflow)
DEBATE_MODELS=claude-sonnet,gpt-4o,gemini-2.5-pro
PM_MODEL=gpt-4o-mini
SYNTHESIZER_MODEL=claude-sonnet

# LangChain Tracing (optional)
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=true

# Phase Configuration
PHASE_TIMEOUT_SECONDS=60
MAX_DEBATE_ROUNDS=3

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# FastAPI / Server
API_HOST=0.0.0.0
API_PORT=8000

# Frontend (Next.js)
NEXT_PUBLIC_API_HOST=localhost:8000
BACKEND_URL=http://localhost:8000

# GitHub (for Gstar skill and MCP integration)
# Generate at: https://github.com/settings/tokens
# Required scopes: repo (read+write), read:user
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=salafadidas
